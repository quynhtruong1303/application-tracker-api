    {
      "name": "POST /applications - Create a new application",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201)",
              "})",
              "",
              "pm.test(\"Response has application data\", function () {",
              "    const body = pm.response.json()",
              "    pm.expect(body._id).to.exist",
              "    pm.expect(body.company).to.equal('Google')",
              "    pm.expect(body.role).to.equal('Software Engineer')",
              "})",
              "",
              "pm.collectionVariables.set(\"applicationId\", pm.response.json()._id)",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
